SUNBIRD_BASE_URL=https://api.sunbird.ai
SUNBIRD_TOKEN=replace-with-your-token
# Comma-separated fallback endpoints; proxy tries each until one works.
SUNBIRD_TRANSLATE_ENDPOINTS=/tasks/translate
PORT=8787

# Proxy performance tuning
TRANSLATE_CONCURRENCY=8
SUNBIRD_REQUEST_TIMEOUT_MS=20000
SUNBIRD_RETRY_COUNT=1
TRANSLATION_CACHE_MAX_ENTRIES=5000


